# Django Settings Module
# ປ່ຽນເປັນ 'core.settings.prod' ສຳລັບ production
DJANGO_SETTINGS_MODULE=core.settings.dev

# Secret Key (ປ່ຽນສຳລັບ production)
DJANGO_SECRET_KEY=your-secret-key-here

# Database Configuration (PostgreSQL for Production)
DB_NAME=pythonforlaos_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@pythonforlaos.com

# Admin URL (ປ່ຽນສຳລັບຄວາມປອດໄພ)
ADMIN_URL=secret-admin/

# Redis Cache (ຖ້າໃຊ້)
REDIS_URL=redis://127.0.0.1:6379/1

# ============================================
# AI & Machine Learning Configuration
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
DEFAULT_AI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Claude Configuration (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI Model Settings
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TOP_P=1.0

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=python_for_laos_docs

# Celery Configuration (for async AI tasks)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Payment Slip OCR Configuration
TESSERACT_PATH=/usr/local/bin/tesseract
OCR_CONFIDENCE_THRESHOLD=0.7
